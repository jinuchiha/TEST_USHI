# ─── Database (CockroachDB Serverless or Postgres) ──────────────────────────
# Get from cockroachlabs.cloud → cluster → Connect
DB_HOST=your-cluster.aws-ap-southeast-1.cockroachlabs.cloud
DB_PORT=26257
DB_NAME=defaultdb
DB_USER=your_username
DB_PASSWORD=your_password_here
DB_SSL=true
DB_SSL_MODE=require
# Set DB_SYNC=true ONLY for first-time setup to auto-create tables.
# After tables are created, set this to false and use migrations for schema changes.
DB_SYNC=true

# ─── Redis (optional, only if running Redis locally) ───────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── JWT (use 32+ char random strings in production) ───────────────────────
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── App ───────────────────────────────────────────────────────────────────
PORT=3000
CORS_ORIGIN=http://localhost:5173
UPLOAD_DIR=./uploads
NODE_ENV=development
