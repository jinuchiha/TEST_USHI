# Staging Environment
NODE_ENV=staging
PORT=3000

# Database
DB_HOST=staging-postgres.internal
DB_PORT=5432
DB_NAME=debt_recovery_crm_staging
DB_USER=crm_staging
DB_PASSWORD=<set-via-secret>

# Redis
REDIS_HOST=staging-redis.internal
REDIS_PORT=6379

# JWT
JWT_SECRET=<set-via-secret>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App
CORS_ORIGIN=https://staging-crm.yourdomain.com
UPLOAD_DIR=./uploads

# Frontend build arg
VITE_API_URL=https://staging-crm.yourdomain.com
