# Production Environment
NODE_ENV=production
PORT=3000

# Database
DB_HOST=prod-postgres.internal
DB_PORT=5432
DB_NAME=debt_recovery_crm
DB_USER=crm_prod
DB_PASSWORD=<set-via-secret>

# Redis
REDIS_HOST=prod-redis.internal
REDIS_PORT=6379

# JWT
JWT_SECRET=<set-via-secret>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App
CORS_ORIGIN=https://crm.yourdomain.com
UPLOAD_DIR=./uploads

# Frontend build arg
VITE_API_URL=https://crm.yourdomain.com
